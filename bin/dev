#!/usr/bin/env bash
#
# Start the PHP built-in server for the Spora operator install.
# Serves public/dist/ (prebuilt admin UI) and /api/* (kernel).
#
# For full-stack development, start Vite separately:
#   cd vendor/spora-ai/spora-frontend   # if path-installed
#   npm run dev                         # Vite on :5173, proxies /api to PHP
#
# Ports via env (PHP_PORT defaults to 8080).

set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
BASE_DIR="$(dirname "$SCRIPT_DIR")"
PHP_LOG="$BASE_DIR/storage/php.log"

if [[ -f "$BASE_DIR/.env" ]]; then
    set -a
    source "$BASE_DIR/.env"
    set +a
fi

PHP_PORT="${PHP_PORT:-8080}"

mkdir -p "$BASE_DIR/storage"

echo "Starting PHP server on http://localhost:${PHP_PORT} (log: storage/php.log)"
exec php -S "localhost:${PHP_PORT}" -t "$BASE_DIR/public" > "$PHP_LOG" 2>&1
